{
  "name": "gridzo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "npm install && tsc && tsc-alias -p tsconfig.json --resolve-full-paths --resolve-full-extension .js",
    "start": "node dist/index.js",
    "type-check": "tsc --noEmit --project tsconfig.json"
  },
  "dependencies": {
    "@hono/node-server": "^1.14.2",
    "@hono/zod-openapi": "^0.16.4",
    "@supabase/supabase-js": "^2.50.0",
    "@types/node": "^25.6.0",
    "dotenv": "^16.6.1",
    "hono": "^4.6.10",
    "tsc-alias": "^1.8.16",
    "typescript": "^5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "tsx": "^4.20.6"
  }
}
